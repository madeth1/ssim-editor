{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SSIM Editor",
  "version": "0.1.2",
  "identifier": "com.madeth.ssim-editor",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "SSIM Editor",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDhDMkMwODI2QUIzQUNBRTQKUldUa3lqcXJKZ2dzak94TXdkWlNKbHVjVXVNcHZXemtLNUxweW9rcVZtZGZiK1NZUjFpVnJ1MEUK",
      "endpoints": [
        "https://github.com/madeth1/ssim-editor/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
